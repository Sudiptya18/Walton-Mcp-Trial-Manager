{
  "name": "walton-mcp-trial-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "setup:local": "node scripts/setup-local.js",
    "build": "npm run build -w client",
    "start:api": "npm run start -w server",
    "local": "npm run build && npm run start:api",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "preview": "npm run build -w client && npm run preview -w client",
    "migrate": "npm run migrate -w server",
    "migrate:status": "npm run migrate:status -w server",
    "migrate:rollback": "npm run migrate:rollback -w server",
    "seed-admin": "npm run seed-admin -w server",
    "import-trials": "npm run import-trials -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
